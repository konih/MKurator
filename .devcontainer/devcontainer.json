{
  "name": "Kurator DevContainer",
  "image": "golang:1.26.4-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:3": {
      "moby": true,
      "dockerDefaultAddressPool": "base=172.30.0.0/16,size=24"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:2": {
      "upgradePackages": true
    }
  },

  "runArgs": ["--privileged", "--init"],

  "customizations": {
    "vscode": {
      "settings": {
        "go.toolsManagement.autoUpdate": false,
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "golang.go",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-docker",
        "task.vscode-task"
      ]
    }
  },

  "remoteEnv": {
    "GO111MODULE": "on",
    "CGO_ENABLED": "0",
    "PATH": "${containerWorkspaceFolder}/bin:/usr/local/go/bin:/usr/local/bin:${containerEnv:PATH}",
    "KUBECONFIG": "${containerWorkspaceFolder}/hack/kind-cluster/.state/kubeconfig.yaml",
    "TF_VAR_kubeconfig": "${containerWorkspaceFolder}/hack/kind-cluster/.state/kubeconfig.yaml"
  },

  "postCreateCommand": "bash .devcontainer/post-install.sh"
}
